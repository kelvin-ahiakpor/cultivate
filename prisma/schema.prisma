// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Organizations using the platform (Farmitecture, other ag companies, etc.)
model Organization {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique // farmitecture, agritech-co, etc.
  brandName         String?  // "Farmitecture AI Assistant" - for whitelabeling
  logoUrl           String?
  vectorDbNamespace String   @unique // For isolating vector embeddings per org
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  users          User[]
  agents         Agent[]
  knowledgeBases KnowledgeBase[]
  quota          OrganizationQuota?
  apiUsage       ApiUsage[]
  farmerSystems  FarmerSystem[]

  @@map("organizations")
}

// User roles: agronomist, farmer, admin
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  emailVerified  DateTime?
  name           String
  phone          String?
  location       String?  // City/region (e.g., "Accra, Ghana" or "Volta Region")
  gpsCoordinates String?  // GPS coords in "lat,lon" format (e.g., "5.6037,-0.1870")
  password       String   // Hashed password for credentials auth
  role           UserRole @default(FARMER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Multi-tenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relations
  agents         Agent[]
  conversations  Conversation[]
  messages       Message[]
  knowledgeBases KnowledgeBase[]
  flaggedQueries FlaggedQuery[]
  reviewHistory  ReviewHistory[]
  feedback       Feedback[]
  accounts       Account[]
  sessions       Session[]
  farmerSystems  FarmerSystem[]

  @@map("users")
}

enum UserRole {
  AGRONOMIST
  FARMER
  ADMIN
}

// KB Categorization enums
enum KnowledgeBaseType {
  CORE         // Farmitecture-specific (highest priority)
  RELATED      // Adjacent techniques
  GENERAL      // Broad agricultural knowledge
}

enum ContentType {
  FAQ              // Q&A format
  MANUAL           // Step-by-step procedures
  TROUBLESHOOTING  // Problem tables
  GUIDE            // Comprehensive how-to
  THEORETICAL      // Explains concepts
  PRACTICAL        // Actionable instructions
  MIXED            // Theory + practice
  REFERENCE        // Quick lookup
}

enum SourceType {
  INTERNAL_SOP     // Company SOP
  INTERNAL_FAQ     // Company FAQ
  INTERNAL_MANUAL  // Company manual
  GOV_DOCUMENT     // Government docs
  EXTENSION_GUIDE  // University extension
  RESEARCH_PAPER   // Peer-reviewed
  WHITE_PAPER      // Industry paper
  TECHNICAL_MANUAL // Equipment manual
  CASE_STUDY       // Implementation story
  BLOG_POST        // Practitioner blog
  FORUM_POST       // Forum discussion
  VIDEO_TRANSCRIPT // YouTube content
  PRODUCT_SPEC     // Product specs
  VENDOR_GUIDE     // Supplier guide
  PDF_UPLOAD       // Uncategorized
  WEB_SCRAPED      // Web content
  OTHER            // Fallback
}

// AI Agents created by agronomists
model Agent {
  id                  String   @id @default(cuid())
  name                String
  systemPrompt        String   @db.Text
  responseStyle       String?  // friendly, formal, concise, detailed
  confidenceThreshold Float    @default(0.7) // 0-1, route to human if below
  version             Int      @default(1) // For tracking agent config changes
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Multi-tenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relations
  agronomistId String
  agronomist   User   @relation(fields: [agronomistId], references: [id], onDelete: Cascade)

  conversations  Conversation[]
  knowledgeBases AgentKnowledgeBase[]
  flaggedQueries FlaggedQuery[]

  @@map("agents")
}

// Farmer-Agent conversation sessions
model Conversation {
  id        String   @id @default(cuid())
  title     String?  // Auto-generated from first message
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  farmerId String
  farmer   User   @relation(fields: [farmerId], references: [id], onDelete: Cascade)

  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  farmerSystemId String?
  farmerSystem   FarmerSystem? @relation(fields: [farmerSystemId], references: [id], onDelete: SetNull)

  messages Message[]

  @@map("conversations")
}

// Individual messages in conversations
model Message {
  id              String      @id @default(cuid())
  content         String      @db.Text
  role            MessageRole // user or assistant
  confidenceScore Float?      // 0-1, only for assistant messages
  sourcesCited    String[]    // References to knowledge base chunks
  createdAt       DateTime    @default(now())

  // Relations
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation(fields: [senderId], references: [id], onDelete: Cascade)

  feedback     Feedback?
  flaggedQuery FlaggedQuery?
  apiUsage     ApiUsage[]
  attachments  MessageAttachment[]

  @@map("messages")
}

enum MessageRole {
  USER
  ASSISTANT
}

model MessageAttachment {
  id             String                @id @default(cuid())
  fileName       String
  fileUrl        String
  mimeType       String
  attachmentType MessageAttachmentType @default(IMAGE)
  width          Int?
  height         Int?
  createdAt      DateTime              @default(now())

  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("message_attachments")
}

enum MessageAttachmentType {
  IMAGE
}

// Agronomist-uploaded knowledge documents
model KnowledgeBase {
  id          String   @id @default(cuid())
  title       String
  fileName    String
  fileUrl     String   // Cloud storage URL (S3, Supabase Storage)
  fileType    String   // pdf, docx, txt, csv
  chunkCount  Int      @default(0) // Number of chunks created
  version     Int      @default(1) // Track updates to knowledge base
  vectorDbId  String?  // Reference to vector DB collection ID
  isEncrypted Boolean  @default(false) // Flag for sensitive proprietary data
  uploadedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // KB Categorization
  kbType      KnowledgeBaseType @default(RELATED)
  contentType ContentType?       // Optional
  sourceType  SourceType         @default(PDF_UPLOAD)
  description String?            @db.Text

  // Multi-tenancy - uses org's vectorDbNamespace for isolation
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relations
  agronomistId String
  agronomist   User   @relation(fields: [agronomistId], references: [id], onDelete: Cascade)

  agents AgentKnowledgeBase[]

  // Note: Document chunks are now managed by Mastra PgVector (@mastra/pg)
  // No Prisma relation needed - chunks stored in Mastra's vector store with knowledgeBaseId in metadata

  @@map("knowledge_bases")
}

// Many-to-many join table for KB-to-Agent assignments
model AgentKnowledgeBase {
  id              String   @id @default(cuid())
  agentId         String
  knowledgeBaseId String
  isPrimary       Boolean  @default(false) // First assigned agent = primary
  assignedAt      DateTime @default(now())

  agent         Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  knowledgeBase KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@unique([agentId, knowledgeBaseId])
  @@map("agent_knowledge_bases")
}

// Low-confidence queries needing agronomist review
model FlaggedQuery {
  id                 String             @id @default(cuid())
  status             FlaggedQueryStatus @default(PENDING)
  farmerReason       String?            @db.Text // Initial reason from farmer
  farmerUpdates      String?            @db.Text // Subsequent updates from farmer (chronological)
  agronomistResponse String?            @db.Text
  verificationNotes  String?            @db.Text
  reviewedAt         DateTime?
  createdAt          DateTime           @default(now())

  // Relations
  messageId String  @unique
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  agronomistId String
  agronomist   User   @relation(fields: [agronomistId], references: [id], onDelete: Cascade)

  reviewHistory ReviewHistory[]

  @@map("flagged_queries")
}

// Audit trail for flagged query reviews
model ReviewHistory {
  id                 String             @id @default(cuid())
  action             ReviewAction       // VERIFIED, CORRECTED, REVOKED, EDITED
  statusBefore       FlaggedQueryStatus // Status before this action
  statusAfter        FlaggedQueryStatus // Status after this action
  agronomistResponse String?            @db.Text // Snapshot of response at time of action
  verificationNotes  String?            @db.Text // Snapshot of notes at time of action
  createdAt          DateTime           @default(now())

  // Relations
  flaggedQueryId String
  flaggedQuery   FlaggedQuery @relation(fields: [flaggedQueryId], references: [id], onDelete: Cascade)

  agronomistId String
  agronomist   User   @relation(fields: [agronomistId], references: [id], onDelete: Cascade)

  @@map("review_history")
}

enum ReviewAction {
  VERIFIED  // Initial verification
  CORRECTED // Initial correction
  EDITED    // Edited existing review
  REVOKED   // Revoked review (back to PENDING)
}

enum FlaggedQueryStatus {
  PENDING
  VERIFIED
  CORRECTED
}

// Farmer feedback on AI responses
model Feedback {
  id        String   @id @default(cuid())
  rating    Int      // 1-5 stars
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  // Relations
  messageId String  @unique
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  farmerId String
  farmer   User   @relation(fields: [farmerId], references: [id], onDelete: Cascade)

  @@map("feedback")
}

// Track API usage for cost control and analytics
model ApiUsage {
  id           String   @id @default(cuid())
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  totalCost    Float    @default(0) // Cost in USD
  endpoint     String   // "chat", "embedding", etc.
  model        String   // "claude-sonnet-4.5", etc.
  createdAt    DateTime @default(now())

  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  messageId String?
  message   Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt]) // For querying org usage over time
  @@map("api_usage")
}

// Organization usage limits and quotas
model OrganizationQuota {
  id                String   @id @default(cuid())
  monthlyTokenLimit Int?     // Null = unlimited (for paid plans)
  monthlyBudgetUSD  Float?   // Null = unlimited
  currentMonthUsage Int      @default(0)
  currentMonthCost  Float    @default(0)
  resetDate         DateTime // When to reset counters
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_quotas")
}

// Document chunks are now managed by Mastra PgVector (@mastra/pg)
// Mastra creates its own vector store tables automatically
// Chunks are linked to knowledge bases via metadata (not Prisma relations)

// Farming systems/products a farmer has purchased (e.g. Farmitecture equipment)
// Self-registered by farmer after purchase, or added by admin on their behalf.
model FarmerSystem {
  id               String       @id @default(cuid())
  name             String       // "Hydroponic NFT System - Medium"
  type             String       // "Hydroponic System", "Irrigation System", etc.
  description      String       @db.Text
  status           SystemStatus @default(PENDING_SETUP)
  purchaseDate     DateTime
  installationDate DateTime?
  warrantyUntil    DateTime?
  specifications   Json?        // { size, capacity, material, ... }
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relations
  farmerId       String
  farmer         User         @relation(fields: [farmerId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  conversations Conversation[]

  @@index([farmerId])
  @@map("farmer_systems")
}

enum SystemStatus {
  ACTIVE
  PENDING_SETUP
  INACTIVE
}

// NextAuth.js Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
