# Database
# Runtime app traffic on serverless: Supabase Transaction Pooler
DATABASE_URL="postgresql://user:password@aws-1-region.pooler.supabase.com:6543/postgres"

# Prisma CLI / migrations / Studio: direct Postgres connection
DIRECT_URL="postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres"

# NextAuth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here"

# Full URL of your application
# Development: http://localhost:3000
# Production: https://your-domain.com
AUTH_URL="http://localhost:3000"

# Anthropic API
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-api03-..."

# Optional: Vector Database (Pinecone or Weaviate)
# PINECONE_API_KEY=""
# PINECONE_ENVIRONMENT=""
# WEAVIATE_URL=""
# WEAVIATE_API_KEY=""

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@yourapp.com"
